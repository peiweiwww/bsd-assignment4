{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:shared": "npm run build --workspace=packages/shared",
    "predev:worker": "npm run build:shared",
    "dev:worker": "npm run dev --workspace=apps/worker",
    "dev:web": "npm run dev --workspace=apps/web",
    "prebuild:worker": "npm run build:shared",
    "build:worker": "npm run build --workspace=apps/worker",
    "prebuild:web": "npm run build:shared",
    "build:web": "npm run build --workspace=apps/web",
    "predev:web": "npm run build:shared",
    "build": "npm run build --workspaces --if-present"
  }
}
